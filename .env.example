# Copy this file to .env and fill in real values.
# The .env file is in .gitignore and must never be committed.

# -- JWT -----------------------------------------------------------------------
# Must be at least 32 characters. Use a password manager to generate this.
JWT__Secret=your-super-secret-key-minimum-32-characters-long
JWT__Issuer=APIDoctorCheckUp
JWT__Audience=APIDoctorCheckUp
JWT__ExpiryHours=12

# -- Admin Account -------------------------------------------------------------
# Single admin account — no registration system. Change before deploying.
Admin__Username=admin
Admin__Password=change-me-before-deploy

# -- Database ------------------------------------------------------------------
# Local development uses SQLite — no setup required, just run the app.
ConnectionStrings__DefaultConnection=Data Source=apidoctorcheckup.db

# Production uses PostgreSQL on Neon.tech. Replace with your actual connection string.
# ConnectionStrings__DefaultConnection=Host=...;Database=...;Username=...;Password=...;Ssl Mode=Require

# -- CORS ----------------------------------------------------------------------
# Local dev: Angular runs on 4200. Add your Vercel URL for production.
Cors__AllowedOrigins__0=http://localhost:4200
# Cors__AllowedOrigins__1=https://your-app.vercel.app

# -- Email Alerts (Day 14 stretch feature) ------------------------------------
# Resend__ApiKey=
# Alerts__FromEmail=
# Alerts__ToEmail=
